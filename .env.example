# Server
PORT=3000

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://lexai:lexai@localhost:5432/lexai_whatsapp_bot?schema=public"

# Redis (BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# lexai-backend (the actual document upload/analysis/chat API this bot bridges to)
LEXAI_BACKEND_URL="http://localhost:4000"
# Shared secret for the proposed POST /auth/whatsapp-link endpoint on lexai-backend
# (see README "Known Integration Gap" — this endpoint does not exist yet).
LEXAI_WHATSAPP_LINK_SECRET=""

# WhatsApp Cloud API (Meta for Developers > your App > WhatsApp > API Setup)
# Token used to verify the webhook subscription challenge (you choose this value yourself
# when configuring the webhook in the Meta App dashboard).
WHATSAPP_VERIFY_TOKEN=""
# Permanent access token for a System User with whatsapp_business_messaging permission.
WHATSAPP_ACCESS_TOKEN=""
# Phone Number ID (not the phone number itself) shown in API Setup.
WHATSAPP_PHONE_NUMBER_ID=""
# WhatsApp Business Account (WABA) ID shown in API Setup.
WHATSAPP_BUSINESS_ACCOUNT_ID=""
